<?xml version="1.0"?>
<robot name="puzzlebot">
	<material name="black2">
		<color rgba="0.05 0.05 0.05 1.0" />
	</material>
	<material name="grey">
		<color rgba="0.55 0.55 0.58 1.0" />
	</material>
	<material name="black">
		<color rgba="0.05 0.05 0.05 1.0" />
	</material>

	<link name="base_footprint" />

	<link name="base_link">
		<visual>
			<geometry>
				<mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl" />
			</geometry>
			<material name="black2" />
		</visual>
		<collision>
			<origin xyz="0 0 0.0" rpy="0 0 0" />
			<geometry>
				<box size="0.23 0.19 0.07" />
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<mass value="2.0" />
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.03" />
		</inertial>
	</link>

	<link name="wheel_left_link">
		<visual>
			<origin xyz="0 0 0" rpy="1.5708 0 0" />
			<geometry>
				<mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Wheel.stl" />
			</geometry>
			<material name="black" />
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="1.5708 0 0" />
			<geometry>
				<cylinder length="0.02" radius="0.033" />
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<mass value="0.15" />
			<inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001" />
		</inertial>
	</link>

	<link name="wheel_right_link">
		<visual>
			<origin xyz="0 0 0" rpy="1.5708 0 0" />
			<geometry>
				<mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Wheel.stl" />
			</geometry>
			<material name="black" />
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="1.5708 0 0" />
			<geometry>
				<cylinder length="0.02" radius="0.033" />
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<mass value="0.15" />
			<inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001" />
		</inertial>
	</link>

	<link name="caster_holder_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
				<mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Caster_Wheel.stl" />
			</geometry>
			<material name="black" />
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
				<box size="0.04 0.04 0.02" />
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<mass value="0.08" />
			<inertia ixx="8e-05" ixy="0.0" ixz="0.0" iyy="8e-05" iyz="0.0" izz="8e-05" />
		</inertial>
	</link>

	<link name="wheel_caster_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
				<sphere radius="0.014" />
			</geometry>
			<material name="grey" />
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
				<sphere radius="0.014" />
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<mass value="0.03" />
			<inertia ixx="2e-05" ixy="0.0" ixz="0.0" iyy="2e-05" iyz="0.0" izz="2e-05" />
		</inertial>
	</link>

	<joint name="base_joint" type="fixed">
		<parent link="base_footprint" />
		<child link="base_link" />
		<origin xyz="0 0 0.05" rpy="0 0 0" />
	</joint>

	<joint name="wheel_left_joint" type="continuous">
		<parent link="base_link" />
		<child link="wheel_left_link" />
		<origin xyz="0.052 0.095 -0.0025" rpy="0 0 0" />
		<axis xyz="0 1 0" />
	</joint>

	<joint name="wheel_right_joint" type="continuous">
		<parent link="base_link" />
		<child link="wheel_right_link" />
		<origin xyz="0.052 -0.095 -0.0025" rpy="0 0 0" />
		<axis xyz="0 1 0" />
	</joint>

	<joint name="caster_holder_joint" type="fixed">
		<parent link="base_link" />
		<child link="caster_holder_link" />
		<origin xyz="-0.095 0 -0.03" rpy="0 0 0" />
	</joint>

	<joint name="wheel_caster_joint" type="fixed">
		<parent link="caster_holder_link" />
		<child link="wheel_caster_link" />
		<origin xyz="0 0 -0.014" rpy="0 0 0" />
	</joint>
</robot>
